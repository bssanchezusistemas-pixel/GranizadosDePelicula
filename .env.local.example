# Copia este archivo a .env.local y rellena con tus datos reales de Supabase
# (Proyecto Supabase → Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Solo en servidor (server actions de caja). Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Firma HMAC de la cookie mesero_session (mín. 16 caracteres). Genera uno aleatorio:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=tu-secreto-aleatorio-min-16-chars

# Opcional: emails admin (coma-separados) si aún no usas app_metadata.role = "admin"
# ADMIN_EMAILS=admin@tudominio.com

# Impresora térmica (servicio local en PC de caja — ver print-bridge/README.md)
NEXT_PUBLIC_PRINT_BRIDGE_URL=http://127.0.0.1:9101
