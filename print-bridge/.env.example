# Nombre en Windows (para detectar IP automaticamente)
PRINTER_NAME=POS-58C

# auto = detecta red o usa Windows | tcp = Ethernet directo | winspool = cola Windows
PRINTER_MODE=auto

# Solo si la impresora va por cable de RED (Ethernet):
# PRINTER_MODE=tcp
# PRINTER_HOST=192.168.1.100
# PRINTER_PORT=9100

PRINTER_WIDTH=32

PORT=9101
HOST=127.0.0.1

ALLOWED_ORIGINS=http://localhost:3000,https://granizados-de-pelicula.vercel.app
