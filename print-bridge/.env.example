# Nombre EXACTO de la impresora en Windows (Configuracion - Impresoras)
PRINTER_NAME=LR1100

# Modo share = recomendado (no requiere driver npm). INSTALAR.bat configura el resto.
PRINTER_MODE=share
PRINTER_SHARE=LR1100

PORT=9101
HOST=127.0.0.1

# Origenes permitidos (coma-separados). Incluye tu URL de Vercel.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://tu-dominio.vercel.app
