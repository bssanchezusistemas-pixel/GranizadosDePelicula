# Nombre exacto de la impresora en Windows (Configuracion - Impresoras)
PRINTER_NAME=LR1100

# Si falla el driver, comparte la impresora en Windows y descomenta UNA opcion:
# PRINTER_SHARE=LR1100
# PRINTER_INTERFACE=\\localhost\LR1100

PORT=9101
HOST=127.0.0.1

# Origenes permitidos (coma-separados). Incluye tu dominio de produccion.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://tu-dominio.vercel.app
