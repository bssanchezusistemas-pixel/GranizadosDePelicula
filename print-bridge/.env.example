# Nombre EXACTO de Get-Printer (ej. POS-58C)
PRINTER_NAME=POS-58C

# winspool = recomendado en Windows (sin compartir, sin driver npm)
PRINTER_MODE=winspool

# Ancho en caracteres: 32 para 58mm (POS-58C), 48 para 80mm
PRINTER_WIDTH=32

PORT=9101
HOST=127.0.0.1

# Sin barra final al final de la URL
ALLOWED_ORIGINS=http://localhost:3000,https://granizados-de-pelicula.vercel.app
